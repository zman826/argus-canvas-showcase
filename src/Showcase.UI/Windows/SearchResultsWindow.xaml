<Window x:Class="Showcase.UI.Windows.SearchResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CIMA Showcase - Results"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="{StaticResource PrimaryFontFamily}">
    <Grid Margin="60,40,60,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ヘッダー：「○○○○」○件 -->
        <TextBlock Grid.Row="0"
                   x:Name="HeaderText"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#222222"
                   Margin="0,0,0,24" />

        <!-- 2 列カード一覧（縦スクロール） -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultsList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Tag="{Binding CaseId}"
                                Click="OnCardClick"
                                Margin="12"
                                Padding="0"
                                Background="White"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch">
                            <StackPanel>
                                <!-- 写真エリア（実画像は Phase 6 で差替） -->
                                <Rectangle Height="200" Fill="#E8EEF7" />
                                <StackPanel Margin="16,12,16,16">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#222222"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Year}"
                                                   FontSize="15"
                                                   Foreground="#666666" />
                                        <TextBlock Text="　/　"
                                                   FontSize="15"
                                                   Foreground="#999999" />
                                        <TextBlock Text="{Binding Category}"
                                                   FontSize="15"
                                                   Foreground="{StaticResource CimaBrandBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- フッター：ホームへ戻る -->
        <Button Grid.Row="2"
                Content="← ホームへ戻る"
                FontSize="20"
                Background="Transparent"
                BorderThickness="0"
                Foreground="#555555"
                HorizontalAlignment="Left"
                Margin="0,20,0,0"
                Padding="12,8"
                Cursor="Hand"
                Click="OnBackToHome" />
    </Grid>
</Window>
